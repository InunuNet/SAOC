{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/full_boot.sh && echo \"\\n🤖 ATHANOR FRAMEWORK (Athanor v$(cat .agent/version 2>/dev/null || echo '?'))\\nIdentity: $(python3 -c \\\"import json; p=json.load(open('.agent/profile.json')); print(p.get('identity',{}).get('agent_name', p.get('project_name','Agent')))\\\" 2>/dev/null || echo 'Agent') | Boot: OK\\nRead the boot context above before starting.\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '\\n💾 Wrap up: python3 execution/brain.py wrap-up -s \"summary\" -t \"tags\"'"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "analyst|architect|designer|dev|docs|lead|maintainer|qa",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/subagent_start.sh"
          }
        ]
      },
      {
        "matcher": "analyst|architect",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/require_research.sh"
          }
        ]
      },
      {
        "matcher": "dev",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/require_contract.sh"
          }
        ]
      },
      {
        "matcher": "qa",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/require_dev_result.sh"
          }
        ]
      },
      {
        "matcher": "docs",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/require_qa_report.sh"
          }
        ]
      },
      {
        "matcher": "maintainer",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/require_docs.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/require_maintainer.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/check_autonomy.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [{
          "type": "command",
          "command": "fp=$(python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\" 2>/dev/null); case \"$fp\" in */.gemini/MEMORY/*|*/.gemini/PAI/*|*/MEMORY/LEARNING/*|*/MEMORY/WORK/*) exit 2 ;; esac"
        }]
      },
      {
        "matcher": "Edit",
        "hooks": [{
          "type": "command",
          "command": "fp=$(python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\" 2>/dev/null); case \"$fp\" in */.gemini/MEMORY/*|*/.gemini/PAI/*|*/MEMORY/LEARNING/*|*/MEMORY/WORK/*) exit 2 ;; esac"
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "bash execution/hooks/verify_workspace.sh"
        }]
      }
    ],
    "AfterTool": [
      {
        "matcher": "analyst|architect|designer|dev|docs|lead|maintainer|qa",
        "hooks": [
          {
            "type": "command",
            "command": "bash execution/hooks/subagent_stop.sh"
          }
        ]
      }
    ]
  },
  "general": {
    "defaultApprovalMode": "auto_edit"
  },
  "policyPaths": ["./.gemini/policies/autonomy.toml"]
}