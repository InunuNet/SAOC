{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Skill",
      "ToolSearch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(dd if=/dev/zero*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)"
    ],
    "ask": [
      "Bash(chmod 777 *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/full_boot.sh ] && bash execution/hooks/full_boot.sh || exit 0"
          },
          {
            "type": "command",
            "command": "echo \"You are now operating within the $(jq -r '.project_name // \"Athanor\"' .agent/profile.json) Agentic Workspace (v$(cat .agent/version)). Identity: $(jq -r '.identity.agent_name // \"Athanor Agent\"' .agent/profile.json) | Identity Status: Active. A full boot context was just injected above — framework identity (AGENTS.md), workspace, last session, project rules, goals, learned, backlog, brain recall, blockers, and git remotes. Read the injected BOOT CONTEXT carefully. You have 8 specialized agents at your disposal (@lead, @dev, @designer, etc.). Your primary goal is autonomous self-improvement for this project. Report boot status using this exact format: ✅ ATHANOR: [name] | 🤖 Agents: 8 roles active | Last session: [1-line summary] | Goals: [count] active | Backlog: [count] open items | Rules loaded: yes | ➡️ Ready.\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CHANGED=$(git diff --stat HEAD 2>/dev/null | wc -l | tr -d ' '); if [ \"$CHANGED\" -gt 0 ]; then echo 'Session had uncommitted changes — run /wrap-up at start of next session.'; fi"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_maintainer.sh ] && bash execution/hooks/require_maintainer.sh || exit 0"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); trigger=$(printf '%s' \"$input\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('compaction_trigger','unknown'))\" 2>/dev/null || echo 'unknown'); recent=$(git log --oneline -5 2>/dev/null | tr '\\n' '; ' || echo 'no git'); python3 execution/brain.py remember --summary \"Pre-compaction checkpoint ($trigger). Recent commits: $recent\" --tags \"compaction,checkpoint\" 2>/dev/null || true",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "printf '{\"systemMessage\": \"COMPACT FORMAT MANDATE — Target <=1500 tokens total. INCLUDE: file paths changed (1 line each), key decisions (1 line each), active mission + current feature checkpoint, blockers. EXCLUDE: inline code blocks, file contents, error transcripts, verbatim tool output, large diffs. Use 1-line bullets only. Never quote content verbatim. Ruthlessly concise — summary is context, not a record.\"}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/post_compact_restore.sh ] && bash execution/hooks/post_compact_restore.sh || exit 0",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/post_compact_inject.sh ] && bash execution/hooks/post_compact_inject.sh || exit 0",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/harness_heartbeat.sh ] && bash execution/hooks/harness_heartbeat.sh || exit 0",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/inject_pressure.sh ] && bash execution/hooks/inject_pressure.sh || exit 0",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "analyst|architect|designer|dev|docs|lead|maintainer|qa",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/subagent_start.sh ] && bash execution/hooks/subagent_start.sh || exit 0",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "analyst|architect|designer|dev|docs|lead|maintainer|qa",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/subagent_stop.sh ] && bash execution/hooks/subagent_stop.sh || exit 0",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/block_asq_in_loop.sh ] && bash execution/hooks/block_asq_in_loop.sh || exit 0"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/check_autonomy.sh ] && bash execution/hooks/check_autonomy.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_contract_for_write.sh ] && bash execution/hooks/require_contract_for_write.sh || exit 0"
          },
          {
            "type": "command",
            "command": "fp=$(cat | python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\" 2>/dev/null); case \"$fp\" in */.claude/MEMORY/*|*/MEMORY/LEARNING/*|*/.claude/PAI/*) exit 2 ;; esac"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/check_autonomy.sh ] && bash execution/hooks/check_autonomy.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_contract_for_write.sh ] && bash execution/hooks/require_contract_for_write.sh || exit 0"
          },
          {
            "type": "command",
            "command": "fp=$(cat | python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\" 2>/dev/null); case \"$fp\" in */.claude/MEMORY/*|*/MEMORY/LEARNING/*|*/.claude/PAI/*) exit 2 ;; esac"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/check_autonomy.sh ] && bash execution/hooks/check_autonomy.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/verify_workspace.sh ] && bash execution/hooks/verify_workspace.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_docs.sh ] && bash execution/hooks/require_docs.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_maintainer.sh ] && bash execution/hooks/require_maintainer.sh || exit 0"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_research.sh ] && bash execution/hooks/require_research.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_contract.sh ] && bash execution/hooks/require_contract.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_dev_result.sh ] && bash execution/hooks/require_dev_result.sh || exit 0"
          },
          {
            "type": "command",
            "command": "[ -f execution/hooks/require_qa_report.sh ] && bash execution/hooks/require_qa_report.sh || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/post_agent_loop_continue.sh ] && bash execution/hooks/post_agent_loop_continue.sh || exit 0"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f execution/hooks/quota_death_checkpoint.sh ] && bash execution/hooks/quota_death_checkpoint.sh || exit 0",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "$ANTHROPIC_DEFAULT_HAIKU_MODEL"
  },
  "autoCompactEnabled": true
}